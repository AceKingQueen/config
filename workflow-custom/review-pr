#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=pr-resolve.sh
source "$SCRIPT_DIR/pr-resolve.sh"

INPUT="${1:-}"
BASE_BRANCH="${2:-origin/main}"

if [[ -z "$INPUT" ]]; then
  echo "Usage: review-pr <PR_NUMBER | BRANCH | TICKET> [BASE_BRANCH]"
  echo "Examples:"
  echo "  review-pr 3039"
  echo "  review-pr UH-235"
  echo "  review-pr feat/auth-gateway-permissions-integration"
  exit 1
fi

PR="$(resolve_pr "$INPUT")" || exit 1
[[ "$INPUT" != "$PR" ]] && echo "🔎 Resolved '$INPUT' → PR #$PR"

# Workspace
OUT_DIR="$HOME/Documents/reviews/pr-${PR}-review"
OUT_FILE="$HOME/Documents/reviews/pr-${PR}-review.md"

mkdir -p "$OUT_DIR"

echo "Fetching PR metadata..."
gh pr view "$PR" --json number,title,body,baseRefName,headRefName,author,url,createdAt >"${OUT_DIR}/pr-info.json"

echo "👯 Exporting PR diff..."
gh pr diff "$PR" >"${OUT_DIR}/pr.patch"

echo "Exporting changed file list..."
gh pr view "$PR" --json files --jq '.files[].path' >"${OUT_DIR}/changed-files.txt"

echo "🌳 Checking out PR locally..."
gh pr checkout "$PR" >/dev/null

# gh emits repo-root-relative paths (e.g. web_apps/apps/...), but the capture
# loops below test `-f "$f"` against the CWD. Without this, running review-pr
# from a subdirectory silently skips every file and the bundle is diff-only.
cd "$(git rev-parse --show-toplevel)"

echo "Capturing file contents for context..."
while IFS= read -r f; do
  if [[ ! -f "$f" ]]; then
    echo "⚠️ Skipping missing file (probably deleted): $f" >>"${OUT_DIR}/files-missing.txt"
  fi
done <"${OUT_DIR}/changed-files.txt"

echo "👷🏻 Building review bundle..."
{
  echo "=== PR INFO ==="
  cat "${OUT_DIR}/pr-info.json"
  echo ""
  echo ""

  echo "=== PR DESCRIPTION ==="
  gh pr view "$PR" --json body --jq '.body'
  echo ""
  echo ""

  echo "=== DIFF ==="
  cat "${OUT_DIR}/pr.patch"
  echo ""
  echo ""

  while IFS= read -r f; do
    if [[ -f "$f" ]]; then
      echo "=== FILE: $f ==="
      cat "$f"
      echo ""
      echo ""
    fi
  done <"${OUT_DIR}/changed-files.txt"
} >"$OUT_FILE"

rm -rf "$OUT_DIR"

echo ""
echo "💫 Done! Paste this same prompt into BOTH Claude and Codex:"
echo ""
echo "---------------------------------------------------------------"
echo "Review this PR as a senior full stack engineer. Read the file at: $OUT_FILE"
echo ""
echo "Save your review as a markdown document to one of these paths,"
echo "depending on which assistant you are:"
echo "  • $HOME/Documents/reviews/pr-${PR}-claude-feedback.md   ← if you are Claude"
echo "  • $HOME/Documents/reviews/pr-${PR}-codex-feedback.md    ← if you are Codex"
echo "For every item include the file path and line number. Use these sections:"
echo "- 🚨 Critical Issues"
echo "- ⚠️ Warnings"
echo "- 💡 Nice to Haves"
echo "- ✅ Looks Good"
echo "---------------------------------------------------------------"
echo ""
echo "👉 Next: run \`cross-review-pr ${PR}\` once both feedback files exist."
